{
  "manifest_version": 3,
  "name": "Plagiarism Checker Pro",
  "version": "1.0.0",
  "description": "Pre-submission plagiarism check — select text on any page and check AI/plagiarism risk instantly.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:8080/*", "https://*.plagiarismchecker.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icon16.png", "32": "icon32.png", "48": "icon48.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "icons": { "48": "icon48.png", "128": "icon128.png" }
}
